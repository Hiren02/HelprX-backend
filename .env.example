# Application
NODE_ENV=development
PORT=5000
APP_NAME=HelprX

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=helprx_db
DB_USER=postgres
DB_PASSWORD=your_password
DB_DIALECT=postgres
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Google Gemini AI (for matching service)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe (Optional - for global payments)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# MSG91 (Alternative SMS)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=your_msg91_sender_id
MSG91_ROUTE=4

# Firebase Cloud Messaging (Push Notifications)
FCM_PROJECT_ID=your_firebase_project_id
FCM_PRIVATE_KEY=your_firebase_private_key
FCM_CLIENT_EMAIL=your_firebase_client_email
FCM_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# Email (NodeMailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
EMAIL_FROM=noreply@helprx.com

# Redis (for caching and queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Matching Service
MATCHING_RADIUS_KM=10
MATCHING_MAX_WORKERS=10
MATCHING_TIMEOUT_MS=5000
USE_AI_MATCHING=false

# Pricing
BASE_SERVICE_FEE=50
PLATFORM_COMMISSION_PERCENT=15
SURGE_MULTIPLIER_MAX=2.5

# Worker Settings
WORKER_ACCEPTANCE_TIMEOUT_MINUTES=5
MIN_WORKER_RATING=3.0

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
